# Copy to `.env.local` and fill in. None are required to run the placeholder UI;
# they switch on Convex and UploadThing once the backend/upload flow are built.

# Convex — from `npx convex dev` (creates the deployment + prints these).
# Without NEXT_PUBLIC_CONVEX_URL the app runs fine but skips the Convex provider.
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# UploadThing — from the UploadThing dashboard (App settings → API keys).
UPLOADTHING_TOKEN=
