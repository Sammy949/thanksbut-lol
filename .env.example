# Copy to `.env.local` and fill in. None are required to run the placeholder UI;
# they switch on Convex and UploadThing once the backend/upload flow are built.

# Convex — from `npx convex dev` (creates the deployment + prints these).
# Without NEXT_PUBLIC_CONVEX_URL the app runs fine but skips the Convex provider.
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# UploadThing — from the UploadThing dashboard (App settings → API keys).
UPLOADTHING_TOKEN=

# Reaction anti-abuse — server-trusted anonymous sessions.
# REACTION_SESSION_SECRET signs the httpOnly session cookie (Next side). Generate
# with: openssl rand -base64 32
# CONVEX_REACTION_SECRET is a shared secret gating the internal reaction write so
# only the /api/react route (not a forged browser call) can move the count. Set
# the SAME value in the Convex dashboard (Settings → Environment Variables).
REACTION_SESSION_SECRET=
CONVEX_REACTION_SECRET=
